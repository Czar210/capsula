# Copie para `.env` e preencha. SEM isso, o login ao vivo fica desabilitado,
# mas a demo (mock) e o upload do histórico (GDPR) funcionam normalmente.

# Client ID do app no Spotify Developer Dashboard (https://developer.spotify.com/dashboard)
VITE_SPOTIFY_CLIENT_ID=

# Opcional. Default = origin atual + "/". Tem que ser BYTE-idêntico ao
# registrado no dashboard. Dev: http://127.0.0.1:5173/  (nunca "localhost")
# Prod: https://SEU-PROJETO.vercel.app/
# VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/
